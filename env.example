# ── Text Generation ──────────────────────────────
OPENAI_API_KEY=sk-...           # https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=sk-ant-...    # https://console.anthropic.com/
GROQ_API_KEY=gsk_...            # https://console.groq.com/
GEMINI_API_KEY=...              # https://aistudio.google.com/

# ── Voice Generation ─────────────────────────────
ELEVENLAB_API_KEY=...           # https://elevenlabs.io/
ELEVENLAB_VOICE_ID=21m00Tcm4TlvDq8ikWAM   # default voice

# ── Image Generation ─────────────────────────────
STABILITY_API_KEY=sk-...        # https://platform.stability.ai/
REPLICATE_API_KEY=r8_...        # https://replicate.com/
# DALL-E uses OPENAI_API_KEY automatically

# Note: You don't need ALL keys — the system auto-falls back
# to the next available provider if one fails or is missing.
