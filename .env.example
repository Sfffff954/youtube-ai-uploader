# https://console.cloud.google.com/

# ============================================
# OPENAI API - Für Text/Video-Generierung
# ============================================
# Hol dir deinen Key hier: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...dein-key-hier...

# ============================================
# ELEVENLAB API - Für AI-Stimmen
# ============================================
# Hol dir deinen Key hier: https://elevenlabs.io/
ELEVENLAB_API_KEY=...dein-key-hier...
ELEVENLAB_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ============================================
# STABILITYAI API - Für Bilder generieren
# ============================================
# Hol dir deinen Key hier: https://platform.stability.ai/
STABILITY_API_KEY=...dein-key-hier...

# ============================================
# VIDEO EINSTELLUNGEN
# ============================================
VIDEO_TITLE=Mein AI Video
VIDEO_DESCRIPTION=Dieses Video wurde mit KI erstellt
