# ============================================
# YOUTUBE API
# ============================================
# Download client_secrets.json from Google Cloud
# https://console.cloud.google.com/

# ============================================
# OPENAI API - For Text/Script Generation
# ============================================
# Get your API key here: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# ============================================
# ELEVENLAB API - For AI Voice Generation
# ============================================
# Get your API key here: https://elevenlabs.io/
ELEVENLAB_API_KEY=...your-key-here...
ELEVENLAB_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ============================================
# STABILITYAI API - For Image Generation
# ============================================
# Get your API key here: https://platform.stability.ai/
STABILITY_API_KEY=...your-key-here...

# ============================================
# VIDEO SETTINGS
# ============================================
VIDEO_TITLE=My AI Video
VIDEO_DESCRIPTION=This video was created with AI automation
